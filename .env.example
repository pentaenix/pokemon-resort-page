# Local Operations Desk only — copy to .env.local (never commit secrets).

# GitHub Issues import (Bugs tab → Community GitHub issues)
GITHUB_TOKEN=
# Optional override; otherwise parsed from public/data/site.json repoUrl
GITHUB_REPO=your-name/pokemon-resort

# Libretro box art (Game Library tab) — no token required
# LIBRETRO_THUMBNAILS_BASE=https://thumbnails.libretro.com
